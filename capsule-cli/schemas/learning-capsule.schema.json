{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capsule-registry.dev/schemas/learning-capsule.schema.json",
  "title": "Learning Capsule",
  "description": "Schema for a learning capsule — a self-contained course distributed via the Capsule Registry",
  "type": "object",
  "required": [
    "class_id",
    "version",
    "title",
    "description",
    "author",
    "content_modules",
    "difficulty",
    "pass_criteria"
  ],
  "properties": {
    "class_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique course identifier (UUID v4)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "description": "Course title"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Course description"
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "github": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "default": [],
      "description": "Array of class_id UUIDs this course depends on"
    },
    "tutor_persona": {
      "oneOf": [
        { "type": "string", "description": "Simple persona name" },
        {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "style": {
              "type": "string",
              "enum": ["socratic", "direct", "encouraging", "strict", "casual"],
              "default": "socratic"
            },
            "voice_id": { "type": "string" },
            "system_prompt_override": { "type": "string", "maxLength": 2000 }
          },
          "additionalProperties": false
        }
      ],
      "description": "AI tutor personality for this course"
    },
    "pass_criteria": {
      "type": "object",
      "required": ["min_score"],
      "properties": {
        "min_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Minimum overall score to pass (0-100)"
        },
        "required_labs": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Module IDs of labs that must be completed"
        },
        "required_quizzes": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Module IDs of quizzes that must be passed"
        },
        "custom_rubric": {
          "type": "string",
          "maxLength": 1000,
          "description": "Free-text rubric for AI evaluation"
        }
      },
      "additionalProperties": false
    },
    "content_modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "path", "order"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "type": {
            "type": "string",
            "enum": ["lesson", "lab", "quiz", "resource"]
          },
          "title": { "type": "string", "minLength": 1 },
          "path": {
            "type": "string",
            "description": "Relative path to the content file"
          },
          "order": { "type": "integer", "minimum": 0 },
          "duration_minutes": { "type": "integer", "minimum": 1 },
          "prerequisites": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Module IDs that must be completed first"
          }
        },
        "additionalProperties": false
      }
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "expert"]
    },
    "estimated_hours": {
      "type": "number",
      "minimum": 0.5,
      "description": "Estimated hours to complete"
    },
    "language": {
      "type": "string",
      "default": "en",
      "description": "ISO 639-1 language code"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "icon": {
      "type": "string",
      "description": "Emoji or icon identifier"
    }
  },
  "additionalProperties": false
}
